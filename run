#!/usr/bin/bash


[ $1 == "test" ] && { curl -X POST -d '{"name":"Bob"}' http://localhost:80/v1/d/say_hello; exit; }
[ $1 == "firebase" ] && { curl -X POST -d '{"Message":"1234"}' http://localhost:80/v1/f/send_lifestyle; exit; }

[ $1 ] && sudo docker-compose -f docker-compose.yaml build


sudo docker-compose -f docker-compose.yaml up
